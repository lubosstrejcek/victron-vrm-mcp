# victron-vrm-mcp — example environment file
# ---------------------------------------------------------------------------
# Copy this to .env (ignored by git) and adjust as needed.
# Node 20.6+ can load it directly:  node --env-file=.env dist/index.js
#
# IMPORTANT: This server does NOT read a VRM token from the environment.
# VRM tokens MUST be passed per-request in the Authorization: Bearer header.
# Never put a VRM access token in this file.
# ---------------------------------------------------------------------------

# --- HTTP listener ---------------------------------------------------------

# Port the Streamable HTTP transport binds to.
# PORT=3000

# Bind address. Default 127.0.0.1 — change only if you understand the security
# implications (exposes the MCP endpoint on all interfaces).
# HOST=127.0.0.1

# Path the MCP endpoint is served from.
# MCP_PATH=/mcp


# --- VRM auth scheme -------------------------------------------------------

# Which scheme the server uses when forwarding the caller's token to VRM.
# Valid values: Token | Bearer
#   Token  → personal access tokens (the supported path from 2026-06-01 onwards)
#   Bearer → DEPRECATED. Accepted only for /auth/loginAsDemo testing; a warning
#            is logged whenever this scheme is used.
# Callers can override this on a per-request basis with the
# `x-vrm-auth-scheme: Token|Bearer` header.
# VRM_AUTH_SCHEME=Token


# --- Scope restrictions ----------------------------------------------------

# Comma-separated allowlist of idSite values this server will act on. If unset,
# any site the caller's token can access is allowed. Use in multi-tenant or
# shared deployments to keep the blast radius tight.
# VRM_ALLOWED_SITES=151734,219742

# Comma-separated allowlist of Origin header values. Defense against DNS
# rebinding. If unset, the server accepts same-origin requests and loopback
# only. Set to the exact origins of clients you expect (e.g. the Anthropic
# Messages API's origin, your own web app, etc.).
# ALLOWED_ORIGINS=https://claude.ai,https://app.yourservice.example
