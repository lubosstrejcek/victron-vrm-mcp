  "repository": {
    "type": "git",
    "url": "https://github.com/lubosstrejcek/victron-vrm-mcp.git"
  },
  "homepage": "https://github.com/lubosstrejcek/victron-vrm-mcp",
  "author": "Lubos Strejcek",
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  }
