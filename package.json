{
  "name": "victron-vrm-mcp",
  "version": "0.2.0",
  "description": "MCP server for Victron Energy VRM cloud API — remote, HTTPS, Connector-compatible",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "victron-vrm-mcp": "dist/index.js"
  },
  "files": [
